    "@mikro-orm/migrations": "^7.1.3",
    "@mikro-orm/sql": "^7.1.3",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",

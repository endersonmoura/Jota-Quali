PORT=3333
NODE_ENV=development
AUTH_SECRET=jota-quali-dev-secret
AUTH_TOKEN_TTL_SECONDS=28800

# Option 1: use a full connection string
# DB_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=JotaQuali;User ID=your-user;Password=your-password;Encrypt=true;TrustServerCertificate=false;

# Option 2: use discrete fields
DB_SERVER=your-server.database.windows.net
DB_PORT=1433
DB_NAME=JotaQuali
DB_USER=your-user
DB_PASSWORD=your-password
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
